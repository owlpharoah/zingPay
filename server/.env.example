# ── SolPay server env ─────────────────────────────────────────────────────────
# Copy to .env for local dev; on Vercel set these in Project → Settings → Env Vars.

# REQUIRED. JSON array of the claim authority secret key (e.g. [12,34,...]).
# Must correspond to EXPECTED_CLAIM_AUTHORITY below — the server refuses to start
# otherwise. Gasless claims and sponsored registration cannot work without it.
CLAIM_AUTHORITY_KEYPAIR=

# Solana / program config (defaults target devnet). Use a paid RPC in production —
# getProgramAccounts scans (claim lookup + refund cron) are heavy on public RPCs.
SOLANA_RPC_URL=https://api.devnet.solana.com
PROGRAM_ID=3mxRLcYoNynggNLDtpe9iZXMBoomYXQQPFHVAapzc3iZ
USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
PROVIDER_USDC_ATA=DbQYAzzdGajKZPJV4brtGy6d9UWbDEUjpDTeWyxCKrtg
EXPECTED_CLAIM_AUTHORITY=5JWiQfGELyHtntzkiDgs57PGTHgAFQ3D5ia5S6RdJjpz

# URLs. APP_URL builds the claim link in SMS; ALLOWED_ORIGIN is the CORS allowlist
# (set both to your deployed frontend origin in production).
APP_URL=http://localhost:3000
ALLOWED_ORIGIN=http://localhost:3000

# Twilio (OTP + claim SMS). Without these the OTP/notify routes return 503.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SID=
TWILIO_SMS_FROM=

# Refund cron. CRON_SECRET guards POST/GET /cron/refund — Vercel automatically
# sends it as `Authorization: Bearer <CRON_SECRET>` on scheduled invocations.
# REFUND_CRON_MAX caps refund txs per run (keeps the function within maxDuration).
CRON_SECRET=
REFUND_CRON_MAX=15

# Local dev only (Vercel sets PORT itself).
PORT=3001
